## Produção/homologação (Neon) — descomentar e preencher:
## DATABASE_URL: connection string "pooled" (via PgBouncer), usada pela aplicação em runtime
## DIRECT_DATABASE_URL: connection string "direct", usada só por `prisma migrate` (PgBouncer não suporta prepared statements)
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/looma?sslmode=require&pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/looma?sslmode=require"

REDIS_URL="redis://redis:6379"
JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRES_IN="7d"
S3_ENDPOINT="http://minio:9000"
S3_ACCESS_KEY="looma"
S3_SECRET_KEY="looma123456"
S3_BUCKET="looma-files"
PORT=3000

DATABASE_URL="postgresql://neondb_owner:npg_lLYJM0y6UOcT@ep-misty-hat-acatwa0o-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_DATABASE_URL="postgresql://neondb_owner:npg_lLYJM0y6UOcT@ep-misty-hat-acatwa0o.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
