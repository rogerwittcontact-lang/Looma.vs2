// Looma Domain Schema v1.1 -> Prisma
// Convenção: campos computados (Pendência, estado de Relacionamento, urgência)
// NÃO existem como modelo aqui — são resolvidos em Application Services.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ───────────────────────── Camada Conta ─────────────────────────

enum AccountType {
  PESSOA
  ORGANIZACAO
}

model Account {
  id             String       @id @default(uuid())
  type           AccountType
  displayName    String
  createdAt      DateTime     @default(now())

  person         Person?
  organization   Organization?

  participations Participation[]

  relationshipsAsA Relationship[] @relation("RelationshipAccountA")
  relationshipsAsB Relationship[] @relation("RelationshipAccountB")

  projectsAsPayer Project[] @relation("ProjectPayer")
  projectsAsPayee Project[] @relation("ProjectPayee")

  templates      Template[]

  @@map("accounts")
}

model Person {
  accountId    String   @id
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  email        String   @unique
  passwordHash String
  phone        String?
  document     String?
  languages    String[] @default([])
  availability String?
  avatarUrl    String?

  organizationMemberships OrganizationMember[]

  @@map("people")
}

enum InternalRole {
  DONO
  ADMIN
  MEMBRO
}

model Organization {
  accountId                String   @id
  account                  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  legalName                String
  document                 String   @unique
  restrictProjectCreation  Boolean  @default(false)

  members                  OrganizationMember[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [accountId], onDelete: Cascade)
  personId       String
  person         Person       @relation(fields: [personId], references: [accountId], onDelete: Cascade)
  internalRole   InternalRole
  joinedAt       DateTime     @default(now())

  @@unique([organizationId, personId])
  @@map("organization_members")
}

// ───────────────────── Camada Relacionamento ─────────────────────

model Relationship {
  id          String   @id @default(uuid())
  accountAId  String
  accountA    Account  @relation("RelationshipAccountA", fields: [accountAId], references: [id])
  accountBId  String
  accountB    Account  @relation("RelationshipAccountB", fields: [accountBId], references: [id])
  createdAt   DateTime @default(now())

  dossier     Dossier?
  messages    Message[]
  projects    Project[]

  @@unique([accountAId, accountBId])
  @@map("relationships")
}

model Dossier {
  relationshipId          String       @id
  relationship            Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  preferredPaymentMethod  String?
  defaultApprovers        Json?        // lista de personId
  brandAssets             Json?        // logos, fontes, cores
  defaultContractFileId   String?
  address                 String?
  taxDocument             String?

  @@map("dossiers")
}

model Message {
  id                    String       @id @default(uuid())
  relationshipId        String
  relationship          Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  authorParticipationId String?
  authorParticipation   Participation? @relation(fields: [authorParticipationId], references: [id])
  content               String
  createdAt             DateTime     @default(now())

  @@index([relationshipId, createdAt])
  @@map("messages")
}

// ───────────────────────── Camada Projeto ─────────────────────────

enum TemplateOrigin {
  SISTEMA
  USUARIO
  COMPARTILHADO
}

model Template {
  id            String   @id @default(uuid())
  name          String
  createdByType TemplateOrigin
  accountId     String?
  account       Account? @relation(fields: [accountId], references: [id])

  versions      TemplateVersion[]

  @@map("templates")
}

model TemplateVersion {
  id                  String   @id @default(uuid())
  templateId          String
  template            Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  versionNumber       Int
  deliverableStructure Json    // lista de { deliverableTypeId, nome }
  createdAt           DateTime @default(now())

  projects            Project[]

  @@unique([templateId, versionNumber])
  @@map("template_versions")
}

model Project {
  id                  String          @id @default(uuid())
  relationshipId      String
  relationship        Relationship    @relation(fields: [relationshipId], references: [id])
  templateVersionId   String
  templateVersion     TemplateVersion @relation(fields: [templateVersionId], references: [id])
  name                String
  objective           String?
  totalBudget         Decimal?        @db.Decimal(12, 2)
  generalDeadline     DateTime?
  payerAccountId      String
  payerAccount        Account         @relation("ProjectPayer", fields: [payerAccountId], references: [id])
  payeeAccountId      String
  payeeAccount        Account         @relation("ProjectPayee", fields: [payeeAccountId], references: [id])
  createdAt           DateTime        @default(now())

  participations      Participation[]
  deliverables        Deliverable[]
  activities          Activity[]
  briefingResponses   BriefingResponse[]
  state               ProjectState?
  financeEntries      Finance[]

  @@index([relationshipId])
  @@index([payerAccountId])
  @@index([payeeAccountId])
  @@map("projects")
}

enum ParticipationRole {
  OWNER
  MANAGER
  EDITOR
  REVIEWER
  VIEWER
}

model Participation {
  id            String            @id @default(uuid())
  projectId     String
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account           @relation(fields: [accountId], references: [id])
  role          ParticipationRole
  deliverableId String?
  deliverable   Deliverable?      @relation(fields: [deliverableId], references: [id])
  joinedAt      DateTime          @default(now())

  activities       Activity[]
  decisions        RegisteredDecision[]
  authoredMessages Message[]

  @@unique([projectId, accountId])
  @@map("participations")
}

// ───────────────────────── Camada Entrega ─────────────────────────

enum ProofingComponent {
  PLAYER_TIMESTAMP
  PIN_IMAGEM
  ESTAGIOS
  COMPARACAO_LOTE
}

model DeliverableType {
  id                        String   @id @default(uuid())
  name                      String   @unique
  technicalBriefingStructure Json    // campos específicos do briefing técnico
  defaultSubtasks           Json     // lista de nomes padrão
  proofingComponent         ProofingComponent

  deliverables       Deliverable[]
  workflowDefinition WorkflowDefinition?

  @@map("deliverable_types")
}

// ADR-005: política de decisão vive aqui, não no DeliverableType diretamente
model WorkflowDefinition {
  id                String          @id @default(uuid())
  deliverableTypeId String          @unique
  deliverableType   DeliverableType @relation(fields: [deliverableTypeId], references: [id], onDelete: Cascade)
  jsonDefinition    Json            // ex.: { "cliente": "PRIMEIRA_DECISAO_VENCE", "juridico": "OBRIGATORIO" }

  @@map("workflow_definitions")
}

model Deliverable {
  id                String          @id @default(uuid())
  projectId         String
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverableTypeId String
  deliverableType   DeliverableType @relation(fields: [deliverableTypeId], references: [id])
  name              String
  createdAt         DateTime        @default(now())

  subtasks          Subtask[]
  activities        Activity[]
  briefingResponses BriefingResponse[]
  state             DeliverableState?
  participations    Participation[]
  financeEntries    Finance[]

  @@index([projectId])
  @@map("deliverables")
}

model Subtask {
  id            String      @id @default(uuid())
  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  name          String
  completed     Boolean     @default(false)
  order         Int

  @@index([deliverableId])
  @@map("subtasks")
}

enum BriefingOrigin {
  HERDADO_DOSSIE
  PREENCHIDO_MANUAL
  SUGERIDO_IA_CONFIRMADO
}

model BriefingResponse {
  id            String       @id @default(uuid())
  projectId     String?
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverableId String?
  deliverable   Deliverable? @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  field         String
  value         String
  origin        BriefingOrigin

  @@index([projectId, field])
  @@index([deliverableId, field])
  @@map("briefing_responses")
}

// ───────────────────────── Camada Workflow ─────────────────────────

enum ProjectStateEnum {
  ORCAMENTO
  NEGOCIACAO
  CONTRATO_ASSINADO
  EM_PRODUCAO
  ENTREGUE
  CONCLUIDO
  ARQUIVADO
}

model ProjectState {
  projectId String           @id
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  state     ProjectStateEnum
  enteredAt DateTime         @default(now())

  @@index([state])
  @@map("project_states")
}

enum DeliverableStateEnum {
  NAO_INICIADA
  EM_PRODUCAO
  EM_REVISAO
  APROVADA
  ENTREGUE
}

model DeliverableState {
  deliverableId String               @id
  deliverable   Deliverable          @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  state         DeliverableStateEnum
  enteredAt     DateTime             @default(now())

  @@index([state])
  @@map("deliverable_states")
}

enum ApprovalState {
  PENDENTE
  APROVADO
  REJEITADO
}

model Approval {
  id         String        @id @default(uuid())
  activityId String        @unique
  activity   Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  state      ApprovalState @default(PENDENTE)

  decisions  RegisteredDecision[]

  @@map("approvals")
}

model RegisteredDecision {
  id              String        @id @default(uuid())
  approvalId      String
  approval        Approval      @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  participationId String
  participation   Participation @relation(fields: [participationId], references: [id])
  decision        String        // "APROVAR" | "REJEITAR" | ação específica do papel
  decidedAt       DateTime      @default(now())

  @@unique([approvalId, participationId])
  @@map("registered_decisions")
}

// ───────────────────── Camada Atividade / Timeline ─────────────────────

enum ActivityType {
  COMENTARIO
  ARQUIVO
  APROVACAO
  FINANCEIRO
  SISTEMA
  IA
  COMPROMISSO
  VERSAO
}

enum ActorType {
  PARTICIPACAO
  SISTEMA
  IA
  INTEGRACAO
}

model Activity {
  id                    String         @id @default(uuid())
  projectId             String?
  project               Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverableId         String?
  deliverable           Deliverable?   @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  type                  ActivityType
  actorType             ActorType
  actorParticipationId  String?
  actorParticipation    Participation? @relation(fields: [actorParticipationId], references: [id])
  payload               Json
  payloadVersion        Int            @default(1)
  createdAt             DateTime       @default(now())

  approval              Approval?
  fileReferences        FileReference[]

  @@index([projectId, createdAt])
  @@index([deliverableId, createdAt])
  @@index([type])
  @@map("activities")
}

model StoredFile {
  id         String   @id @default(uuid())
  storageKey String
  hash       String
  mime       String
  sizeBytes  Int
  name       String

  references FileReference[]

  @@map("stored_files")
}

model FileReference {
  id         String     @id @default(uuid())
  fileId     String
  file       StoredFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity   @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("file_references")
}

// ───────────────────────── Camada Financeiro ─────────────────────────

enum FinanceStatus {
  PENDENTE
  AGENDADO
  CONFIRMADO
}

model Finance {
  id                 String        @id @default(uuid())
  projectId          String
  project            Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverableId      String?
  deliverable        Deliverable?  @relation(fields: [deliverableId], references: [id])
  amount             Decimal       @db.Decimal(12, 2)
  status             FinanceStatus @default(PENDENTE)
  triggerActivityId  String?

  @@index([projectId, status])
  @@map("finance_entries")
}
