{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "node -e \"require('dns').lookup('ep-misty-hat-acatwa0o.sa-east-1.aws.neon.tech', {all:true}, (e,r)=>{console.log('ERRO:', e); console.log('RESULTADO:', r); process.exit(0)})\"",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
